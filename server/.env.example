# PostgreSQL connection string
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/careerlens

# Secret key for signing JWT tokens (use a long random string)
JWT_SECRET=your_super_secret_jwt_key_here

# Base URL of the ML microservice
ML_SERVICE_URL=http://localhost:8000

# Port the Express server listens on
PORT=3001

# Google Gemini API key (get one at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here
